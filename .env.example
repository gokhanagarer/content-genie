# Demo runs WITHOUT any of these set — the offline stubs produce a complete
# end-to-end pipeline so reviewers can see real output in 30 seconds.

# Required for LIVE LLM output (article + outline + plan). Free tier available.
# https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Required to actually fetch images from Pollinations.ai instead of writing a placeholder PNG.
LIVE=0

# Required only if you pass --publish (or set publish in the orchestrator).
WP_SITE_URL=
WP_USER=
WP_APP_PASSWORD=

# Generation knobs
CONTENT_LANGUAGE=English
TARGET_WORD_COUNT=1800
